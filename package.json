{
  "name": "safi-studio-scanner",
  "version": "0.1.0",
  "description": "Terminal website audit tool. Crawls pages and reports SEO, content, links, images, structured data, security, and crawlability issues.",
  "author": {
    "name": "Abdulkader Safi",
    "url": "https://safi-studio.com"
  },
  "homepage": "https://github.com/Abdulkader-Safi/Safi-Studio-Scanner#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Abdulkader-Safi/Safi-Studio-Scanner.git"
  },
  "bugs": {
    "url": "https://github.com/Abdulkader-Safi/Safi-Studio-Scanner/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "scanner": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "node --test --import tsx \"test/*.test.ts\"",
    "prepare": "tsc"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cheerio": "^1.0.0"
  },
  "optionalDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "playwright": "^1.61.1",
    "playwright-core": "^1.61.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "license": "UNLICENSED",
  "private": true
}
